/******************************************************************************
 * test_matrix: 2x2 행렬 곱 (B는 1/0/-1만)
 *
 * Goal : 2x2 행렬 곱을 MicroCPU로 구현한다.
 *        B 원소가 1/0/-1이므로 곱셈 없이 ADD/SUB/SKIP으로 구현.
 *
 * 16비트 명령어 형식: opc_m_rd_rs_d[7:0]
 *   opc[15:13] — 명령어 종류 (3비트)
 *   m[12]      — 0: 메모리 모드, 1: 레지스터 모드
 *   rd[11:10]  — 대상 레지스터 (R0~R3)
 *   rs[9:8]    — 소스 레지스터 (mode=1일 때)
 *   d[7:0]     — 메모리 주소 또는 즉시값
 *
 * opcode 인코딩:
 *   000 WFR  정지
 *   001 BRZ  R[rd]=0이면 PC+2 (skip)
 *   010 BRA  PC <- data
 *   011 LDA  m=0: R[rd] <- mem[data]
 *            m=1: R[rd] <- R[rs]
 *   100 STA  mem[data] <- R[rd]
 *   101 ADD  m=0: R[rd] <- R[rd] + mem[data]
 *            m=1: R[rd] <- R[rd] + R[rs]
 *   110 AND  m=0: R[rd] <- R[rd] & mem[data]
 *            m=1: R[rd] <- R[rd] & R[rs]
 *   111 NOT  R[rd] <- ~R[rd]
 *
 *
 * 메모리 맵:
 *   0x00~0x14: 코드 영역 (unroll)
 *   0x80~0x83: A[2][2] = {2, 3, 4, 5}
 *   0x88~0x8B: C[2][2] = 결과 저장
 *   0x90~0x91: 상수 (1, 0)
 *
 * 정상 실행 흐름:
 * 
 * A = {{2, 3}, {4, 5}}
 * B = {{1, -1}, {0, 1}}
 * C = A * B = {{2, 1}, {4, 1}}
 *
 *   C[0][0] = A[0][0]*1 + A[0][1]*0 = 2
 *     PC=0x00 LDA R0,[0x91]  R0=0
 *     PC=0x01 ADD R0,[0x80]  R0=2 (B=1)
 *     PC=0x02 STA [0x88]    C[0][0]=2
 *
 *   C[0][1] = A[0][0]*(-1) + A[0][1]*1 = -2+3 = 1
 *     PC=0x03 LDA R0,[0x91]  R0=0
 *     PC=0x04~0x07 NOT+ADD로 -A[0][0]
 *     PC=0x08 ADD R0,[0x81]  R0=-2+3=1
 *     PC=0x09 STA [0x89]    C[0][1]=1
 *
 *   C[1][0] = A[1][0]*1 + A[1][1]*0 = 4
 *     PC=0x0A LDA R0,[0x91]  R0=0
 *     PC=0x0B ADD R0,[0x82]  R0=4 (B=1)
 *     PC=0x0C STA [0x8A]    C[1][0]=4
 *
 *   C[1][1] = A[1][0]*(-1) + A[1][1]*1 = -4+5 = 1
 *     PC=0x0D LDA R0,[0x91]  R0=0
 *     PC=0x0E~0x11 NOT+ADD로 -A[1][0]
 *     PC=0x12 ADD R0,[0x83]  R0=-4+5=1
 *     PC=0x13 STA [0x8B]    C[1][1]=1
 *
 *   PC=0x14 WFR -> 행렬 곱 완료!
 *
 * opc_m_rd_rs_dddddddd  //  addr  asm               설명
 *
 *****************************************************************************/

// Comment #1. 행렬 곱 프로그램
// opc_m_rd_rs_dddddddd  //  addr  asm               설명
@00
// --- C[0][0] = A[0][0]*1 + A[0][1]*0 = 2 ---
011_0_00_00_10010001    //  0x00  LDA R0,[0x91]     R0 <- 0
101_0_00_00_10000000    //  0x01  ADD R0,[0x80]     R0 <- 0+2=2 (B=1)
100_0_00_00_10001000    //  0x02  STA [0x88],R0     C[0][0]=2

// --- C[0][1] = A[0][0]*(-1) + A[0][1]*1 = 1 ---
011_0_00_00_10010001    //  0x03  LDA R0,[0x91]     R0 <- 0
011_0_01_00_10000000    //  0x04  LDA R1,[0x80]     R1 <- 2
111_0_01_00_00000000    //  0x05  NOT R1            R1 <- 0xFFFD
101_0_01_00_10010000    //  0x06  ADD R1,[0x90]     R1 <- 0xFFFD+1=0xFFFE (-2)
101_1_00_01_00000000    //  0x07  ADD R0,R1 (m=1)   R0 <- 0+(-2)=-2
101_0_00_00_10000001    //  0x08  ADD R0,[0x81]     R0 <- -2+3=1
100_0_00_00_10001001    //  0x09  STA [0x89],R0     C[0][1]=1

// --- C[1][0] = A[1][0]*1 + A[1][1]*0 = 4 ---
011_0_00_00_10010001    //  0x0A  LDA R0,[0x91]     R0 <- 0
101_0_00_00_10000010    //  0x0B  ADD R0,[0x82]     R0 <- 0+4=4 (B=1)
100_0_00_00_10001010    //  0x0C  STA [0x8A],R0     C[1][0]=4

// --- C[1][1] = A[1][0]*(-1) + A[1][1]*1 = 1 ---
011_0_00_00_10010001    //  0x0D  LDA R0,[0x91]     R0 <- 0
011_0_01_00_10000010    //  0x0E  LDA R1,[0x82]     R1 <- 4
111_0_01_00_00000000    //  0x0F  NOT R1            R1 <- 0xFFFB
101_0_01_00_10010000    //  0x10  ADD R1,[0x90]     R1 <- 0xFFFB+1=0xFFFC (-4)
101_1_00_01_00000000    //  0x11  ADD R0,R1 (m=1)   R0 <- 0+(-4)=-4
101_0_00_00_10000011    //  0x12  ADD R0,[0x83]     R0 <- -4+5=1
100_0_00_00_10001011    //  0x13  STA [0x8B],R0     C[1][1]=1

// --- 완료 ---
000_0_00_00_00000000    //  0x14  WFR               행렬 곱 완료!
// End Comment

// --- Data section ---
@80
0000000000000010        //  0x80  A[0][0] = 2
0000000000000011        //  0x81  A[0][1] = 3
0000000000000100        //  0x82  A[1][0] = 4
0000000000000101        //  0x83  A[1][1] = 5

@88
0000000000000000        //  0x88  C[0][0]
0000000000000000        //  0x89  C[0][1]
0000000000000000        //  0x8A  C[1][0]
0000000000000000        //  0x8B  C[1][1]

@90
0000000000000001        //  0x90  상수 1
0000000000000000        //  0x91  상수 0
