/******************************************************************************
 * MCPUtest3: 레지스터 모드 검증 프로그램 (mode=1, reg-to-reg)
 *
 * MicroCPU의 레지스터 모드 연산(ADD, NOT, AND, MOV)을 검증한다.
 * MCPUtest1, MCPUtest2를 먼저 통과해야 한다.
 * 모든 명령어가 정상이면 addr 0x10의 WFR에서 정지한다.
 *
 * 16비트 명령어 형식: {opcode[15:13], mode[12], rd[11:10], rs[9:8], data[7:0]}
 *   mode=1: rs 필드가 소스 레지스터를 선택한다
 * 인코딩: WFR=000, BRZ=001, BRA=010, LDA=011, STA=100, ADD=101, AND=110, NOT=111
 *
 * 메모리 맵:
 *   0x00~0x11: 코드 영역
 *   0x80~0x82: 데이터 영역
 *
 * 정상 실행 흐름:
 *
 *   1) 레지스터 초기화:
 *      PC=0x00 LDA R0,[0x80]  R0=0x0005
 *      PC=0x01 LDA R1,[0x81]  R1=0x0003
 *
 *   2) MOV 검증: LDA mode=1 -> R2 = R1
 *      PC=0x02 LDA R2,R1 (mode=1)  R2=0x0003
 *
 *   3) NOT+ADD로 뺄셈 검증: R2 - R1 = 3 - 3 = 0
 *      PC=0x03 NOT R2           R2=0xFFFC
 *      PC=0x04 ADD R2,[0x82]    R2=0xFFFC + 1 = 0xFFFD (-3)
 *      PC=0x05 ADD R2,R1 (m=1)  R2=0xFFFD + 3 = 0x0000
 *      PC=0x06 BRZ R2 -> skip (R2=0)
 *
 *   4) ADD reg 검증: R0 + R1 = 5 + 3 = 8, + (-8) = 0
 *      PC=0x08 ADD R0,R1 (mode=1)  R0=0x0008
 *      PC=0x09 ADD R0,[0x83]       R0=0x0008 + 0xFFF8(-8) = 0x0000
 *      PC=0x0A BRZ R0 -> skip (R0=0)
 *
 *   5) AND reg 검증: 0x0005 & 0x0003 = 0x0001, + (-1) = 0
 *      PC=0x0C LDA R0,[0x80]       R0=0x0005
 *      PC=0x0D AND R0,R1 (mode=1)  R0=0x0005 & 0x0003 = 0x0001
 *      PC=0x0E ADD R0,[0x84]       R0=0x0001 + 0xFFFF(-1) = 0x0000
 *      PC=0x0F BRZ R0 -> skip (R0=0)
 *
 *   6) PC=0x11 WFR (EXPECT_PC = 17)
 *
 *****************************************************************************/

// Code section (0x00~0x12)
011_00000_10000000    //  0x00  LDA     m=0  R0  --  R0 <- mem[0x80](0x0005)
011_00100_10000001    //  0x01  LDA     m=0  R1  --  R1 <- mem[0x81](0x0003)
011_11001_00000000    //  0x02  LDA     m=1  R2  R1  R2 <- R1 (MOV) = 0x0003
111_01000_00000000    //  0x03  NOT     m=0  R2  --  R2 <- ~0x0003 = 0xFFFC
101_01000_10000010    //  0x04  ADD     m=0  R2  --  R2 <- 0xFFFC + 1 = 0xFFFD
101_11001_00000000    //  0x05  ADD     m=1  R2  R1  R2 <- 0xFFFD + 3 = 0x0000
001_01000_00000000    //  0x06  BRZ     m=0  R2  --  R2=0 -> skip
000_00000_00000000    //  0x07  WFR    --
101_10001_00000000    //  0x08  ADD     m=1  R0  R1  R0 <- 0x0005 + 0x0003 = 0x0008
101_00000_10000011    //  0x09  ADD     m=0  R0  --  R0 <- 0x0008 + 0xFFF8 = 0x0000
001_00000_00000000    //  0x0A  BRZ     m=0  R0  --  R0=0 -> skip
000_00000_00000000    //  0x0B  WFR    --
011_00000_10000000    //  0x0C  LDA     m=0  R0  --  R0 <- mem[0x80](0x0005)
110_10001_00000000    //  0x0D  AND     m=1  R0  R1  R0 <- 0x0005 & 0x0003 = 0x0001
101_00000_10000100    //  0x0E  ADD     m=0  R0  --  R0 <- 0x0001 + 0xFFFF = 0x0000
001_00000_00000000    //  0x0F  BRZ     m=0  R0  --  R0=0 -> skip
000_00000_00000000    //  0x10  WFR    --
000_00000_00000000    //  0x11  WFR    --        모든 테스트 통과!
010_00000_00000000    //  0x12  BRA     R0  0x00  0x00으로 다시 실행

// Data section (0x80~0x84)
@80
0000000000000101      //  0x80  0x0005  상수 5
0000000000000011      //  0x81  0x0003  상수 3
0000000000000001      //  0x82  0x0001  상수 1
1111111111111000      //  0x83  0xFFF8  상수 -8
1111111111111111      //  0x84  0xFFFF  상수 -1
