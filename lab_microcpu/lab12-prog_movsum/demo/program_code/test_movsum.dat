/******************************************************************************
 * test_movsum: 이동합 (Moving Sum, window=2)
 *
 * Goal : self-modifying code와 loop으로 배열의 이동합을 계산한다.
 *        y[n] = x[n] + x[n+1], 입력 8개 -> 출력 7개
 *
 * 16비트 명령어 형식: opc_m_rd_rs_d[7:0]
 *   opc[15:13] — 명령어 종류 (3비트)
 *   m[12]      — 0: 메모리 모드, 1: 레지스터 모드
 *   rd[11:10]  — 대상 레지스터 (R0~R3)
 *   rs[9:8]    — 소스 레지스터 (mode=1일 때)
 *   d[7:0]     — 메모리 주소 또는 즉시값
 *
 * opcode 인코딩:
 *   000 WFR  정지
 *   001 BRZ  R[rd]=0이면 PC+2 (skip)
 *   010 BRA  PC <- data
 *   011 LDA  m=0: R[rd] <- mem[data]
 *            m=1: R[rd] <- R[rs]
 *   100 STA  mem[data] <- R[rd]
 *   101 ADD  m=0: R[rd] <- R[rd] + mem[data]
 *            m=1: R[rd] <- R[rd] + R[rs]
 *   110 AND  m=0: R[rd] <- R[rd] & mem[data]
 *            m=1: R[rd] <- R[rd] & R[rs]
 *   111 NOT  R[rd] <- ~R[rd]
 *
 * 메모리 맵:
 *   0x00~0x02: 초기화
 *   0x10~0x14: 이동합 계산
 *   0x20~0x22: x[n+1] 주소 update
 *   0x30~0x32: y[n] 주소 update
 *   0x40~0x43: 카운터 + loop
 *   0x80~0x87: x[8] = {3, 7, 2, 5, 8, 1, 4, 6}
 *   0x90~0x96: y[7] = 결과 저장
 *   0xA0~0xA2: 상수
 *
 * 레지스터 사용:
 *   R0 = x[n] (이전 값)
 *   R1 = x[n+1] (현재 값)
 *   R2 = 임시 (합계, 명령어 수정)
 *   R3 = 카운터 (7->0)
 *
 * self-modifying code:
 *   0x10: LDA R1,[addr] -> 매 iteration addr +1
 *   0x14: STA [addr],R2 -> 매 iteration addr +1
 *
 * 정상 실행 흐름:
 *   초기화: R0=x[0], R3=7
 *   loop:
 *     LDA R1,[x+n+1]    self-modify
 *     R2 = R0 + R1      이동합
 *     R0 = R1            shift
 *     STA [y+n],R2      self-modify
 *     LDA/STA 주소 +1   self-modify
 *     R3--; 
 *     BRZ done; 
 *     BRA loop
 *
 *   결과: y = {10, 9, 7, 13, 9, 5, 10}
 *
 * opc_m_rd_rs_dddddddd  //  addr  asm               설명
 *
 *****************************************************************************/

// Comment #1. 초기화
@00
011_0_00_00_10000000    //  0x00  LDA R0,[0x80]     R0 <- x[0] = 3
011_0_11_00_10100000    //  0x01  LDA R3,[0xA0]     R3 <- 7 (카운터)
010_0_00_00_00010000    //  0x02  BRA 0x10          loop 시작
// End Comment

// Comment #2. y[n] = x[n] + x[n+1]
@10
011_0_01_00_10000001    //  0x10  LDA R1,[0x81]     ← self-modify (x 주소)
011_1_10_00_00000000    //  0x11  LDA R2,R0 (m=1)   R2 <- x[n]
101_1_10_01_00000000    //  0x12  ADD R2,R1 (m=1)   R2 <- x[n] + x[n+1]
011_1_00_01_00000000    //  0x13  LDA R0,R1 (m=1)   R0 <- x[n+1] (shift)
100_0_10_00_10010000    //  0x14  STA [0x90],R2     ← self-modify (y 주소)
010_0_00_00_00100000    //  0x15  BRA 0x20          다음 섹션
// End Comment

// Comment #3. x[n+1] 주소 update with +1
@20
011_0_10_00_00010000    //  0x20  LDA R2,[0x10]     R2 <- 0x10의 명령어
101_0_10_00_10100001    //  0x21  ADD R2,[0xA1]     R2 + 1 (addr 필드 +1)
100_0_10_00_00010000    //  0x22  STA [0x10],R2     0x10 갱신 (0x82,0x83,...)
010_0_00_00_00110000    //  0x23  BRA 0x30          다음 섹션
// End Comment

// Comment #4. y[n] 주소 update with +1
@30
011_0_10_00_00010100    //  0x30  LDA R2,[0x14]     R2 <- 0x14의 명령어
101_0_10_00_10100001    //  0x31  ADD R2,[0xA1]     R2 + 1 (addr 필드 +1)
100_0_10_00_00010100    //  0x32  STA [0x14],R2     0x14 갱신(0x91,0x92,...)
010_0_00_00_01000000    //  0x33  BRA 0x40          다음 섹션
// End Comment

// Comment #5. R3 -1 = 0 이 도달할 때까지 loop back
@40
101_0_11_00_10100010    //  0x40  ADD R3,[0xA2]     R3 + (-1)
001_0_11_00_00000000    //  0x41  BRZ R3            R3=0 -> skip to done
010_0_00_00_00010000    //  0x42  BRA 0x10          loop back
000_0_00_00_00000000    //  0x43  WFR               이동합 완료!
// End Comment

// --- Data section ---
@80
0000000000000011        //  0x80  x[0] = 3
0000000000000111        //  0x81  x[1] = 7
0000000000000010        //  0x82  x[2] = 2
0000000000000101        //  0x83  x[3] = 5
0000000000001000        //  0x84  x[4] = 8
0000000000000001        //  0x85  x[5] = 1
0000000000000100        //  0x86  x[6] = 4
0000000000000110        //  0x87  x[7] = 6

@90
0000000000000000        //  0x90  y[0]
0000000000000000        //  0x91  y[1]
0000000000000000        //  0x92  y[2]
0000000000000000        //  0x93  y[3]
0000000000000000        //  0x94  y[4]
0000000000000000        //  0x95  y[5]
0000000000000000        //  0x96  y[6]

@A0
0000000000000111        //  0xA0  상수 7 (카운터)
0000000000000001        //  0xA1  상수 1
1111111111111111        //  0xA2  상수 -1
